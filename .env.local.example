# ============================================================
#  YEREL KURULUM AYARLARI  (.env.local)
# ------------------------------------------------------------
#  Bu dosyayı ".env.local" adıyla kopyalayın ve isterseniz düzenleyin.
#  Hiçbir şey değiştirmeseniz de varsayılan değerlerle ÇALIŞIR.
#  (kurulum.bat / kurulum.sh bu kopyalamayı sizin için otomatik yapar.)
#
#  Kopyalama:
#     Windows : copy .env.local.example .env.local
#     Mac/Linux: cp .env.local.example .env.local
# ============================================================

# Tarayıcıdan gireceğiniz port -> http://localhost:3030
PORT=3030

# ---- Panele giriş bilgileri (ilk admin kullanıcısı) ----
# İlk kurulumda bu bilgilerle bir admin hesabı otomatik oluşturulur.
# NOT: Bu bilgileri SADECE ilk kurulumdan (veritabanı boşken) ÖNCE değiştirin.
# Kurulumdan sonra şifreyi panel içinden değiştirin.
ADMIN_EMAIL=admin@panel.local
ADMIN_PASSWORD=Admin1234!

# ---- Veritabanı şifresi (yerel; dışarı açık değil) ----
POSTGRES_PASSWORD=yerel_db_sifresi

# ---- Redis şifresi (yerelde boş bırakılır) ----
REDIS_PASSWORD=

# ---- Güvenlik anahtarı (en az 32 karakter) ----
# Gerçek kullanımda buraya rastgele uzun bir değer yazmanız önerilir.
JWT_SECRET=yerel-kurulum-icin-en-az-32-karakter-gizli-anahtar-0001

# ---- WhatsApp (WAHA) panel/dashboard girişi ----
# WhatsApp bağlantısını panel içinden QR okutarak yaparsınız; bunlar
# yalnızca WAHA'nın kendi yönetim ekranı içindir.
WAHA_API_KEY=yerel-waha-anahtari
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=admin
